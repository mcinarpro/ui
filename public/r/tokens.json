{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tokens",
  "title": "Semantic Color Tokens",
  "description": "success / warning / info colors for badge, alert, etc.",
  "cssVars": {
    "theme": {
      "--color-success": "var(--success)",
      "--color-success-foreground": "var(--success-foreground)",
      "--color-warning": "var(--warning)",
      "--color-warning-foreground": "var(--warning-foreground)",
      "--color-info": "var(--info)",
      "--color-info-foreground": "var(--info-foreground)"
    },
    "light": {
      "--success": "oklch(0.72 0.17 145)",
      "--success-foreground": "oklch(0.98 0 0)",
      "--warning": "oklch(0.82 0.16 85)",
      "--warning-foreground": "oklch(0.27 0.03 85)",
      "--info": "oklch(0.62 0.16 250)",
      "--info-foreground": "oklch(0.98 0 0)"
    },
    "dark": {
      "--success": "oklch(0.62 0.15 145)",
      "--success-foreground": "oklch(0.98 0 0)",
      "--warning": "oklch(0.75 0.15 85)",
      "--warning-foreground": "oklch(0.2 0.02 85)",
      "--info": "oklch(0.55 0.15 250)",
      "--info-foreground": "oklch(0.98 0 0)"
    }
  },
  "type": "registry:theme"
}
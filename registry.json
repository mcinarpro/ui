{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "mcinar",
  "homepage": "https://github.com/mcinarpro/ui",
  "items": [
    {
      "name": "utils",
      "type": "registry:lib",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        { "path": "registry/lib/utils.ts", "type": "registry:lib" }
      ]
    },
    {
      "name": "tokens",
      "type": "registry:theme",
      "title": "Semantic Color Tokens",
      "description": "success / warning / info colors for badge, alert, etc.",
      "cssVars": {
        "theme": {
          "--color-success": "var(--success)",
          "--color-success-foreground": "var(--success-foreground)",
          "--color-warning": "var(--warning)",
          "--color-warning-foreground": "var(--warning-foreground)",
          "--color-info": "var(--info)",
          "--color-info-foreground": "var(--info-foreground)"
        },
        "light": {
          "--success": "oklch(0.72 0.17 145)",
          "--success-foreground": "oklch(0.98 0 0)",
          "--warning": "oklch(0.82 0.16 85)",
          "--warning-foreground": "oklch(0.27 0.03 85)",
          "--info": "oklch(0.62 0.16 250)",
          "--info-foreground": "oklch(0.98 0 0)"
        },
        "dark": {
          "--success": "oklch(0.62 0.15 145)",
          "--success-foreground": "oklch(0.98 0 0)",
          "--warning": "oklch(0.75 0.15 85)",
          "--warning-foreground": "oklch(0.2 0.02 85)",
          "--info": "oklch(0.55 0.15 250)",
          "--info-foreground": "oklch(0.98 0 0)"
        }
      }
    },
    {
      "name": "badge",
      "type": "registry:ui",
      "title": "Badge",
      "description": "Badge with success / warning / info variants.",
      "dependencies": ["class-variance-authority", "@base-ui/react"],
      "registryDependencies": ["@mcinar/tokens"],
      "files": [
        { "path": "registry/ui/badge.tsx", "type": "registry:ui" }
      ]
    },
    {
      "name": "alert",
      "type": "registry:ui",
      "title": "Alert",
      "description": "Alert with success / warning / info variants.",
      "dependencies": ["class-variance-authority"],
      "registryDependencies": ["@mcinar/tokens"],
      "files": [
        { "path": "registry/ui/alert.tsx", "type": "registry:ui" }
      ]
    },
    {
      "name": "signin-form",
      "type": "registry:block",
      "title": "Sign In Form",
      "description": "A complete sign in page with email and password validation.",
      "dependencies": ["@tanstack/react-form", "lucide-react", "zod"],
      "registryDependencies": ["button", "card", "input-group", "spinner", "field"],
      "files": [
        { "path": "registry/blocks/signin-form.tsx", "type": "registry:block" }
      ]
    },
    {
      "name": "signup-form",
      "type": "registry:block",
      "title": "Sign Up Form",
      "description": "A complete signup page with name, email, password and confirmation.",
      "dependencies": ["@tanstack/react-form", "lucide-react", "zod"],
      "registryDependencies": ["button", "card", "input-group", "spinner", "field"],
      "files": [
        { "path": "registry/blocks/signup-form.tsx", "type": "registry:block" }
      ]
    },
    {
      "name": "forgot-password-form",
      "type": "registry:block",
      "title": "Forgot Password Form",
      "description": "A forgot password page with email input and success state.",
      "dependencies": ["@tanstack/react-form", "lucide-react", "zod"],
      "registryDependencies": ["button", "card", "input-group", "spinner", "field", "@mcinar/alert"],
      "files": [
        { "path": "registry/blocks/forgot-password-form.tsx", "type": "registry:block" }
      ]
    },
    {
      "name": "reset-password-form",
      "type": "registry:block",
      "title": "Reset Password Form",
      "description": "A reset password page with new password and confirmation.",
      "dependencies": ["@tanstack/react-form", "lucide-react", "zod"],
      "registryDependencies": ["button", "card", "input-group", "spinner", "field", "@mcinar/alert"],
      "files": [
        { "path": "registry/blocks/reset-password-form.tsx", "type": "registry:block" }
      ]
    }
  ]
}

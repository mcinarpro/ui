{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tokens",
  "title": "Semantic Color Tokens",
  "description": "success / warning / info colors for badge, alert, etc.",
  "cssVars": {
    "theme": {
      "--color-success": "var(--success)",
      "--color-success-foreground": "var(--success-foreground)",
      "--color-warning": "var(--warning)",
      "--color-warning-foreground": "var(--warning-foreground)",
      "--color-info": "var(--info)",
      "--color-info-foreground": "var(--info-foreground)"
    },
    "light": {
      "--success": "oklch(0.68 0.18 150)",
      "--success-foreground": "oklch(0.99 0 0)",
      "--warning": "oklch(0.68 0.18 62)",
      "--warning-foreground": "oklch(0.27 0.04 62)",
      "--info": "oklch(0.58 0.18 252)",
      "--info-foreground": "oklch(0.99 0 0)"
    },
    "dark": {
      "--success": "oklch(0.66 0.16 150)",
      "--success-foreground": "oklch(0.99 0 0)",
      "--warning": "oklch(0.74 0.17 62)",
      "--warning-foreground": "oklch(0.22 0.03 62)",
      "--info": "oklch(0.62 0.16 252)",
      "--info-foreground": "oklch(0.99 0 0)"
    }
  },
  "type": "registry:theme"
}